<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

  <class name="clas" table="clas">
    <id name="cid">
      <generator class="assigned" />
    </id>
    <property name="cname" column="cname" length="20" />
    <map name="teacherTimings" table="clasTeacher" cascade="all">
      <key column="cid" />
      <index column="timings" type="string" />
      <many-to-many class="Teacher" column="tid" />
    </map>
  </class>
  <class name="Teacher" table="Teacher">
    <id name="tid">
      <generator teacher="assigned" />
    </id>
    <property name="tname" column="tname" length="20" />
    <property name="subject" column="subject" length="20" />
    <map name="clasTimings" table="clasTeacher" cascade="all">
      <key column="tid" />
      <index column="timings" type="string" />
      <many-to-many class="clas" column="cid" />
    </map>
  </class>

</hibernate-mapping>